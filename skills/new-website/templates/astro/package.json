{
  "name": "site",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build && node scripts/anchor-ids.mjs && node scripts/build-marker.mjs",
    "preview": "astro preview",
    "og": "node scripts/run_og.mjs",
    "ship": "bash scripts/ship.sh",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "check": "astro check",
    "astro": "astro",
    "prepare": "git config core.hooksPath scripts/hooks 2>/dev/null || true"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.0",
    "astro": "^7.1.0",
    "node-html-parser": "^8.0.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "sharp@0.34.5": true,
    "fsevents@2.3.2": true,
    "fsevents@2.3.3": true
  }
}

---
// Crawler-resistant email link. The plaintext address NEVER appears in the HTML
// source: it is reversed + base64-encoded at build time and reassembled in the
// browser. No-JS visitors see a "name [at] domain [dot] com" hint that still reads.
//
//   <EmailLink address="hello@example.com" />
//   <EmailLink address="hello@example.com" subject="Project enquiry" text="Email us" />
import { encodeEmail, emailHint } from '../lib/obfuscate';

interface Props {
  address: string;
  subject?: string;
  text?: string;
  class?: string;
}
const { address, subject, text, class: className } = Astro.props;
const data = encodeEmail(address);
const subj = subject ? encodeURIComponent(subject) : '';
const label = text ?? emailHint(address);
---
<a class:list={['email-link', className]} href="#" data-email={data} data-subject={subj}>{label}</a>

<script>
  // Reassemble on the client; the address is not in the served HTML.
  for (const a of document.querySelectorAll<HTMLAnchorElement>('a.email-link[data-email]')) {
    try {
      const addr = atob(a.dataset.email!).split('').reverse().join('');
      const q = a.dataset.subject ? `?subject=${a.dataset.subject}` : '';
      a.href = `mailto:${addr}${q}`;
      if (a.textContent && a.textContent.includes('[at]')) a.textContent = addr;
      a.removeAttribute('data-email');
      a.removeAttribute('data-subject');
    } catch {
      /* leave the no-JS hint in place */
    }
  }
</script>
